#!/usr/bin/env bash
exec 2>/dev/null  # Claude Code treats any stderr as hook error

# Skip for classifier's internal claude -p calls
[ "${CLAUDE_AUTO_SKILLS_CLASSIFYING:-}" = "1" ] && exit 0

# Check if debug_logger is enabled in config
# Project .claude/auto-skills.local.md > global ~/.claude/auto-skills.local.md
CONFIG=""
[ -f ".claude/auto-skills.local.md" ] && CONFIG=".claude/auto-skills.local.md"
[ -z "$CONFIG" ] && [ -f "$HOME/.claude/auto-skills.local.md" ] && CONFIG="$HOME/.claude/auto-skills.local.md"

ENABLED="false"
if [ -n "$CONFIG" ]; then
    ENABLED=$(sed -n '/^---$/,/^---$/{/^debug_logger:/s/.*: *//p}' "$CONFIG" | head -1)
fi
[ "$ENABLED" != "true" ] && exit 0

# Log hook input
STATEDIR="${CLAUDE_AUTO_SKILLS_STATE:-${XDG_STATE_HOME:-$HOME/.local/state}/claude-auto-skills}"
mkdir -p "$STATEDIR"
LOG_FILE="${STATEDIR}/hook-debug.log"
INPUT=$(cat)
eval "$(echo "$INPUT" | python3 -c "
import sys, json, shlex
try:
    data = json.load(sys.stdin)
    print(f'PROMPT={shlex.quote(data.get(\"prompt\", \"\")[:80])}')
    keys = sorted(data.keys())
    print(f'HOOK_KEYS={shlex.quote(\",\".join(keys))}')
    has_cost = 'true' if 'total_cost_usd' in str(data) else 'false'
    print(f'HAS_COST={has_cost}')
except:
    print('PROMPT=\"parse-error\"')
    print('HOOK_KEYS=\"\"')
    print('HAS_COST=false')
" 2>/dev/null)"
echo "$(date -Is) UserPromptSubmit | keys=${HOOK_KEYS} | has_cost=${HAS_COST} | ${PROMPT}" >> "$LOG_FILE"
