#!/usr/bin/env python3
"""Classifier hook for claude-auto-skills.

Reads UserPromptSubmit hook JSON from stdin, classifies the prompt using
claude -p with Haiku, and outputs the matching skill reminder to stdout
(injected as system-reminder by Claude Code).

Config: .claude/auto-skills.local.md (project) or ~/.claude/auto-skills.local.md (global)
"""

import json
import os
import subprocess
import sys
import re
from datetime import datetime
from pathlib import Path

# Claude Code treats any stderr as hook error — silence it
sys.stderr = open(os.devnull, "w")

# Recursion guard: claude -p triggers UserPromptSubmit hooks too
if os.environ.get("CLAUDE_AUTO_SKILLS_CLASSIFYING") == "1":
    sys.exit(0)
os.environ["CLAUDE_AUTO_SKILLS_CLASSIFYING"] = "1"


# --- Config ---

def parse_local_md(path: Path) -> dict:
    """Parse YAML frontmatter from a .local.md file. Simple parser — no PyYAML dependency."""
    if not path.exists():
        return {}
    text = path.read_text()
    m = re.match(r"^---\s*\n(.*?)\n---", text, re.DOTALL)
    if not m:
        return {}
    frontmatter = m.group(1)

    result = {}
    categories = []
    current_cat = None
    in_categories = False

    for line in frontmatter.splitlines():
        stripped = line.strip()
        if not stripped or stripped.startswith("#"):
            continue

        # Detect categories list
        if line.startswith("categories:"):
            in_categories = True
            continue

        if in_categories:
            if line.startswith("  - name:"):
                if current_cat:
                    categories.append(current_cat)
                current_cat = {"name": line.split(":", 1)[1].strip().strip('"')}
                continue
            if current_cat and line.startswith("    "):
                key, _, val = stripped.partition(":")
                key = key.strip()
                val = val.strip().strip('"')
                if key in ("match", "action"):
                    current_cat[key] = val
                continue
            # End of categories block
            if current_cat:
                categories.append(current_cat)
                current_cat = None
            in_categories = False

        if ":" in line and not line.startswith(" "):
            key, _, val = line.partition(":")
            key = key.strip()
            val = val.strip().strip('"')
            if key and val:
                result[key] = val

    if current_cat:
        categories.append(current_cat)
    if categories:
        result["categories"] = categories
    return result


# Find config: project .claude/auto-skills.local.md > global ~/.claude/auto-skills.local.md
hook_input_raw = sys.stdin.read()
try:
    hook_input = json.loads(hook_input_raw)
except (json.JSONDecodeError, ValueError):
    hook_input = {}

cwd = hook_input.get("cwd", os.getcwd())
project_config = Path(cwd) / ".claude" / "auto-skills.local.md"
global_config = Path.home() / ".claude" / "auto-skills.local.md"

cfg = {}
if project_config.exists():
    cfg = parse_local_md(project_config)
if not cfg and global_config.exists():
    cfg = parse_local_md(global_config)

# Defaults
enabled = cfg.get("enabled", "true")
sensitivity = cfg.get("sensitivity", "normal")
model = cfg.get("model", "claude-haiku-4-5-20251001")
effort = cfg.get("effort", "low")
max_budget = cfg.get("max_budget", "")
low_keywords = cfg.get("low_keywords", "evaluate,investigate,implement,fix,debug,refactor,create,trace,analyze,review,critique,add,write")
subprocess_env = cfg.get("subprocess_env", "CLAUDE_WORKTIME_SKIP_LOG=1")

# State dir for logs
state_dir = Path(
    os.environ.get("CLAUDE_AUTO_SKILLS_STATE")
    or os.path.join(os.environ.get("XDG_STATE_HOME", os.path.expanduser("~/.local/state")), "claude-auto-skills")
)
state_dir.mkdir(parents=True, exist_ok=True)
log_file = state_dir / "classifier.log"

if enabled != "true":
    sys.exit(0)


def log(msg: str) -> None:
    ts = datetime.now().astimezone().isoformat(timespec="seconds")
    try:
        with open(log_file, "a") as f:
            f.write(f"{ts} | {msg}\n")
    except OSError:
        pass


# --- Build categories from config or defaults ---

DEFAULT_CATEGORIES = [
    {
        "name": "code-quality",
        "match": 'User is asking to WRITE, EDIT, CREATE, or IMPLEMENT code — new features, bug fixes, refactoring, file creation. Confirming a proposal to implement counts. Also matches DESIGN CONSTRAINTS or CORRECTIONS directed at code being written: "make it configurable", "extract that into a function", "handle the error case", "add validation", "use the existing helper instead".',
        "action": "Run /auto-skills:code-quality before writing code.",
    },
    {
        "name": "critical-thinking",
        "match": "User is asking to INVESTIGATE, DEBUG, TRACE, or ANALYZE something — find a bug, understand behavior, research a question, explain code.",
        "action": "Run /auto-skills:critical-thinking before proceeding.",
    },
    {
        "name": "critical-evaluation",
        "match": 'User is asking to EVALUATE, COMPARE, CHOOSE, or DECIDE between options, or asking for an opinion on a design, approach, or tradeoff. Includes "should we use X or Y?", "is X the right choice?", "what do you think about X?".',
        "action": "Run /auto-skills:critical-evaluation before responding.",
    },
    {
        "name": "skill-design",
        "match": "User is asking to WRITE, UPDATE, DESIGN, or REVIEW a skill, rule, checklist, or prompt template. Includes creating new skills, modifying existing skill files, or discussing how skills should work.",
        "action": "Run /auto-skills:skill-design before writing or modifying skills.",
    },
]

categories = cfg.get("categories", DEFAULT_CATEGORIES)

# Build classifier prompt sections from categories
cat_lines = ["CATEGORIES (output the line after the arrow if the category matches):\n"]
valid_actions = set()
category_map = {}

for cat in categories:
    name = cat["name"]
    match = cat["match"]
    action = cat["action"]
    cat_lines.append(f"- {name}: {match}\n  → {action}\n")
    valid_actions.add(action)
    category_map[name] = action

categories_text = "\n".join(cat_lines)


# --- Read prompt from hook input ---

prompt = hook_input.get("prompt", "")
transcript_path = hook_input.get("transcript_path", "")

if not prompt:
    log("NO_INPUT")
    sys.exit(0)

# Extract last assistant text from transcript for context
context = ""
if transcript_path and os.path.isfile(transcript_path):
    try:
        last_text = ""
        with open(transcript_path, "r", encoding="utf-8", errors="replace") as f:
            for line in f:
                try:
                    entry = json.loads(line.strip())
                    if entry.get("type") != "assistant":
                        continue
                    content = entry.get("message", {}).get("content", [])
                    if not isinstance(content, list):
                        continue
                    texts = [
                        b.get("text", "")
                        for b in content
                        if isinstance(b, dict) and b.get("type") == "text" and b.get("text", "").strip()
                    ]
                    if texts:
                        last_text = texts[-1]
                except (json.JSONDecodeError, KeyError):
                    continue
        if last_text:
            context = last_text[-300:]
    except OSError:
        pass

log(
    f"DEBUG | transcript_path={transcript_path or '(empty)'} | "
    f"context_len={len(context)} | context_preview={context[:60]} | "
    f"prompt_len={len(prompt)} | prompt={prompt[:60]}"
)

# Build classifier input
if context:
    classifier_input = f"[Last assistant message (truncated)]:\n{context}\n\n[User message to classify]:\n{prompt}"
else:
    classifier_input = f"[User message to classify]:\n{prompt}"

# Apply configured env vars for subprocess
if subprocess_env:
    for pair in subprocess_env.split(","):
        pair = pair.strip()
        if "=" in pair:
            key, _, value = pair.partition("=")
            os.environ[key.strip()] = value.strip()


# --- DO NOT MATCH rules ---

_DO_NOT_MATCH_STRICT = f"""DO NOT MATCH (output nothing for these):
- Anything that doesn't use explicit action keywords ({low_keywords})
- All questions, discussions, confirmations, git operations, documentation updates"""

_DO_NOT_MATCH_NORMAL = """DO NOT MATCH (output nothing for these):
- Short confirmations without implementation context: "yes", "ok", "sure", "sounds good", "go ahead"
- Questions about process or next steps: "what is next?", "what should we do?"
- Requests to continue or deepen discussion: "lets think more", "another round", "keep going"
- Conversational or meta messages: greetings, feedback about the tool, topic changes
- Git operations: "commit this", "push", "create a PR"
- Asking to UPDATE documentation or planning files (roadmaps, notes) — this is not code
- NOTE: "should we use X?" and "what do you think about X?" are NOT discussions — they are evaluation requests, match critical-evaluation"""

_DO_NOT_MATCH_HIGH = """DO NOT MATCH (output nothing for these — be generous, match anything plausible):
- Only skip pure confirmations ("yes", "ok"), greetings, and git operations ("commit", "push")
- "should we use X?" and "what do you think about X?" ARE evaluation prompts — match them"""

_CONTEXT_HINT = """
Use the assistant context (if provided) to disambiguate short messages. "yes" after "shall I implement?" is code-quality. "yes" after "want another design round?" is no match."""

if sensitivity == "low":
    do_not_match = _DO_NOT_MATCH_STRICT
elif sensitivity == "high":
    do_not_match = _DO_NOT_MATCH_HIGH
else:
    do_not_match = _DO_NOT_MATCH_NORMAL

SYSTEM_PROMPT = f"""Classify the user message. Output ONLY matching lines exactly as shown. If none match, output nothing.

{categories_text}

{do_not_match}
{_CONTEXT_HINT}"""


# --- Run classifier ---

cmd = [
    "claude", "-p",
    "--model", model,
    "--effort", effort,
    "--output-format", "json",
]
if max_budget:
    cmd.extend(["--max-budget-usd", max_budget])
cmd.append(SYSTEM_PROMPT)

try:
    result = subprocess.run(
        cmd,
        input=classifier_input,
        capture_output=True,
        text=True,
        timeout=30,
    )
    raw_output = result.stdout
except subprocess.TimeoutExpired:
    log(f"ERROR | claude -p timed out | prompt={prompt[:60]}")
    sys.exit(0)
except OSError as e:
    log(f"ERROR | claude -p failed to start: {e} | prompt={prompt[:60]}")
    sys.exit(0)

if not raw_output:
    log(f"ERROR | claude -p returned empty | prompt={prompt[:60]}")
    sys.exit(0)

# Parse JSON result
try:
    data = json.loads(raw_output)
    classification = data.get("result", "").strip()
    cost = data.get("total_cost_usd", 0)
    api_ms = data.get("duration_api_ms", 0)
    total_ms = data.get("duration_ms", 0)
    tokens_in = data.get("usage", {}).get("input_tokens", 0)
    tokens_out = data.get("usage", {}).get("output_tokens", 0)
except (json.JSONDecodeError, ValueError) as e:
    log(f"ERROR | json parse failed: {e} | raw={raw_output[:100]} | prompt={prompt[:60]}")
    sys.exit(0)

# Filter: only allow expected actions
filtered = []
if classification:
    for line in classification.splitlines():
        cleaned = line.strip().lstrip("-*•→ ").strip()
        # Strip category prefix if present (e.g., "code-quality: Run /...")
        for cat in categories:
            prefix = f"{cat['name']}: "
            if cleaned.lower().startswith(prefix.lower()):
                cleaned = cleaned[len(prefix):].strip()
        if cleaned in valid_actions:
            filtered.append(cleaned)
        elif cleaned.lower() in category_map:
            filtered.append(category_map[cleaned.lower()])

# Log
raw_label = classification.replace("\n", " | ")[:120] if classification else "EMPTY"
filtered_label = " | ".join(filtered) if filtered else "(filtered out)"
log(f"raw={raw_label} | filtered={filtered_label} | ${cost:.6f} {api_ms}ms/{total_ms}ms {tokens_in}in+{tokens_out}out | {prompt[:80]}")

# Output to stdout (injected as system-reminder)
if filtered:
    print("\n".join(filtered))
