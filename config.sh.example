# claude-auto-skills configuration
# Installed to: ~/.config/claude-auto-skills/config.sh
# Override config location with CLAUDE_AUTO_SKILLS_CONFIG env var

# Enable/disable the classifier (default: true)
# Skills remain available manually via /code-quality etc. when disabled
#CLASSIFIER_ENABLED=true

# Classifier model (default: claude-haiku-4-5-20251001)
#CLASSIFIER_MODEL="claude-haiku-4-5-20251001"

# Effort level for classifier (default: low)
#CLASSIFIER_EFFORT="low"

# Max budget per classification call in USD (default: no limit)
#CLASSIFIER_MAX_BUDGET=""

# Sensitivity level: low, normal, high (default: normal)
# low:    Only trigger on explicit action keywords
# normal: Balanced — skips confirmations, discussions, git ops
# high:   Trigger on anything plausible, only skip pure confirmations
#CLASSIFIER_SENSITIVITY="normal"

# Keywords for "low" sensitivity (comma-separated)
#CLASSIFIER_LOW_KEYWORDS="evaluate,investigate,implement,fix,debug,refactor,create,trace,analyze,review,critique,add,write"

# Override the DO NOT MATCH rules entirely (multi-line string)
#CLASSIFIER_DO_NOT_MATCH=""

# Override the CATEGORIES section entirely (multi-line string)
#CLASSIFIER_CATEGORIES=""

# Override state directory (logs)
# Default: ${XDG_STATE_HOME:-~/.local/state}/claude-auto-skills
#CLAUDE_AUTO_SKILLS_STATE=""
