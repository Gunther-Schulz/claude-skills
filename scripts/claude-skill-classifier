#!/usr/bin/env bash
set -euo pipefail

# Recursion guard: claude -p triggers UserPromptSubmit hooks too
if [ "${CLAUDE_SKILL_CLASSIFYING:-}" = "1" ]; then
    exit 0
fi
export CLAUDE_SKILL_CLASSIFYING=1

# Paths: env vars > XDG spec > defaults
CONFIGDIR="${CLAUDE_SKILLS_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/claude-skills}"
STATEDIR="${CLAUDE_SKILLS_STATE:-${XDG_STATE_HOME:-$HOME/.local/state}/claude-skills}"
CONFIGFILE="${CONFIGDIR}/config.sh"
LOG_FILE="${STATEDIR}/classifier.log"

# --- Defaults (overridden by config.sh) ---
CLASSIFIER_ENABLED=true
CLASSIFIER_MODEL="claude-haiku-4-5-20251001"
CLASSIFIER_EFFORT="low"
CLASSIFIER_MAX_BUDGET=""

# Source user config
[ -f "$CONFIGFILE" ] && source "$CONFIGFILE"

# Disabled check (after sourcing config)
[ "$CLASSIFIER_ENABLED" != "true" ] && exit 0

# Ensure state dir exists
mkdir -p "$STATEDIR"

INPUT=$(cat)

# Extract user prompt and transcript path from hook JSON
eval "$(echo "$INPUT" | python3 -c "
import sys, json, shlex
try:
    data = json.load(sys.stdin)
    print(f'PROMPT={shlex.quote(data.get(\"prompt\", \"\"))}')
    print(f'TRANSCRIPT_PATH={shlex.quote(data.get(\"transcript_path\", \"\"))}')
except:
    print('PROMPT=\"\"')
    print('TRANSCRIPT_PATH=\"\"')
" 2>/dev/null)"

if [ -z "$PROMPT" ]; then
    echo "$(date -Is) | NO_INPUT" >> "$LOG_FILE"
    exit 0
fi

# Extract last assistant text from transcript for context
CONTEXT=""
if [ -n "$TRANSCRIPT_PATH" ] && [ -f "$TRANSCRIPT_PATH" ]; then
    CONTEXT=$(python3 -c "
import json, sys
try:
    last_text = ''
    with open(sys.argv[1], 'r') as f:
        for line in f:
            try:
                entry = json.loads(line.strip())
                if entry.get('type') != 'assistant':
                    continue
                content = entry.get('message', {}).get('content', [])
                if not isinstance(content, list):
                    continue
                texts = [b.get('text', '') for b in content
                         if isinstance(b, dict) and b.get('type') == 'text' and b.get('text', '').strip()]
                if texts:
                    last_text = texts[-1]
            except (json.JSONDecodeError, KeyError):
                continue
    # Take the last 300 chars
    if len(last_text) > 300:
        last_text = last_text[-300:]
    print(last_text)
except Exception:
    pass
" "$TRANSCRIPT_PATH" 2>/dev/null || true)
fi

export LOG_FILE
export CLASSIFIER_PROMPT="$PROMPT"

# Debug: log full diagnostic info for tracing
echo "$(date -Is) | DEBUG | transcript_path=${TRANSCRIPT_PATH:-(empty)} | context_len=${#CONTEXT} | context_preview=${CONTEXT:0:60} | prompt_len=${#PROMPT} | prompt=${PROMPT:0:60}" >> "$LOG_FILE"

# Build classifier input with context
if [ -n "$CONTEXT" ]; then
    CLASSIFIER_INPUT="[Last assistant message (truncated)]:
$CONTEXT

[User message to classify]:
$PROMPT"
else
    CLASSIFIER_INPUT="[User message to classify]:
$PROMPT"
fi

# Build claude -p arguments
CLAUDE_ARGS=(--model "$CLASSIFIER_MODEL" --effort "$CLASSIFIER_EFFORT" --output-format json)
[ -n "$CLASSIFIER_MAX_BUDGET" ] && CLAUDE_ARGS+=(--max-budget-usd "$CLASSIFIER_MAX_BUDGET")

# Classify using claude CLI
RAW=$(echo "$CLASSIFIER_INPUT" | claude -p "${CLAUDE_ARGS[@]}" 'Classify the user message. Output ONLY matching lines exactly as shown. If none match, output nothing.

CATEGORIES (output the line after the arrow if the category matches):

- code-quality: User is asking to WRITE, EDIT, CREATE, or IMPLEMENT code — new features, bug fixes, refactoring, file creation. Confirming a proposal to implement counts.
  → Run /code-quality before writing code.

- critical-thinking: User is asking to INVESTIGATE, DEBUG, TRACE, or ANALYZE something — find a bug, understand behavior, research a question, explain code.
  → Run /critical-thinking before proceeding.

- critical-evaluation: User is asking to EVALUATE, REVIEW, or CRITIQUE a specific proposal, design, PR, or approach — not general discussion.
  → Run /critical-evaluation before responding.

DO NOT MATCH (output nothing for these):
- Short confirmations without implementation context: "yes", "ok", "sure", "sounds good", "go ahead"
- Questions about process or next steps: "what is next?", "what should we do?"
- Requests to continue or deepen discussion: "lets think more", "another round", "keep going"
- Conversational or meta messages: greetings, feedback about the tool, topic changes
- Git operations: "commit this", "push", "create a PR"
- Design DISCUSSIONS (talking about how something should work without asking to write code)
- Asking to UPDATE documentation or planning files (roadmaps, notes) — this is not code

Use the assistant context (if provided) to disambiguate short messages. "yes" after "shall I implement?" is code-quality. "yes" after "want another design round?" is no match.' 2>/dev/null || true)

# Check if claude -p failed entirely
if [ -z "$RAW" ]; then
    echo "$(date -Is) | ERROR | claude -p returned empty | prompt=${PROMPT:0:60}" >> "$LOG_FILE"
    exit 0
fi

# Parse JSON, log, filter, and output
echo "$RAW" | python3 -c "
import sys, json, os
from datetime import datetime

log_file = os.environ.get('LOG_FILE', '')
prompt = os.environ.get('CLASSIFIER_PROMPT', '')[:80]
ts = datetime.now().astimezone().isoformat(timespec='seconds')

try:
    data = json.load(sys.stdin)
    result = data.get('result', '').strip()
    cost = data.get('total_cost_usd', 0)
    api_ms = data.get('duration_api_ms', 0)
    total_ms = data.get('duration_ms', 0)
    tokens_in = data.get('usage', {}).get('input_tokens', 0)
    tokens_out = data.get('usage', {}).get('output_tokens', 0)
except Exception as e:
    with open(log_file, 'a') as f:
        f.write(f'{ts} | ERROR | json parse failed: {e} | prompt={prompt}\n')
    sys.exit(0)

# Filter: only allow expected lines (reject hallucinated responses)
VALID = {
    'Run /code-quality before writing code.',
    'Run /critical-thinking before proceeding.',
    'Run /critical-evaluation before responding.',
}
filtered = []
if result:
    for l in result.splitlines():
        cleaned = l.strip().lstrip('-*•→ ').strip()
        for prefix in ('code-quality: ', 'critical-thinking: ', 'critical-evaluation: '):
            if cleaned.lower().startswith(prefix):
                cleaned = cleaned[len(prefix):].strip()
        if cleaned in VALID:
            filtered.append(cleaned)

# Log: raw result + filtered result + cost/duration
raw_label = result.replace(chr(10), ' | ')[:120] if result else 'EMPTY'
filtered_label = ' | '.join(filtered) if filtered else '(filtered out)'
with open(log_file, 'a') as f:
    f.write(f'{ts} | raw={raw_label} | filtered={filtered_label} | \${cost:.6f} {api_ms}ms/{total_ms}ms {tokens_in}in+{tokens_out}out | {prompt}\n')

# Output filtered result to stdout (injected as system-reminder)
if filtered:
    print(chr(10).join(filtered))
" 2>/dev/null

exit 0
