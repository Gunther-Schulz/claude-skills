#!/usr/bin/env bash
set -euo pipefail

# Recursion guard: claude -p triggers UserPromptSubmit hooks too
if [ "${CLAUDE_SKILL_CLASSIFYING:-}" = "1" ]; then
    exit 0
fi
export CLAUDE_SKILL_CLASSIFYING=1

# Paths: env vars > XDG spec > defaults
CONFIGDIR="${CLAUDE_SKILLS_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/claude-skills}"
STATEDIR="${CLAUDE_SKILLS_STATE:-${XDG_STATE_HOME:-$HOME/.local/state}/claude-skills}"
CONFIGFILE="${CONFIGDIR}/config.sh"
LOG_FILE="${STATEDIR}/classifier.log"

# --- Defaults (overridden by config.sh) ---
CLASSIFIER_MODEL="claude-haiku-4-5-20251001"
CLASSIFIER_EFFORT="low"
CLASSIFIER_MAX_BUDGET=""

# Source user config
[ -f "$CONFIGFILE" ] && source "$CONFIGFILE"

# Ensure state dir exists
mkdir -p "$STATEDIR"

INPUT=$(cat)

# Extract user prompt from hook JSON
PROMPT=$(echo "$INPUT" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    print(data.get('prompt', ''))
except:
    pass
" 2>/dev/null)

if [ -z "$PROMPT" ]; then
    echo "$(date -Is) | NO_INPUT" >> "$LOG_FILE"
    exit 0
fi

export LOG_FILE
export CLASSIFIER_PROMPT="$PROMPT"

# Build claude -p arguments
CLAUDE_ARGS=(--model "$CLASSIFIER_MODEL" --effort "$CLASSIFIER_EFFORT" --output-format json)
[ -n "$CLASSIFIER_MAX_BUDGET" ] && CLAUDE_ARGS+=(--max-budget-usd "$CLASSIFIER_MAX_BUDGET")

# Classify using claude CLI
RAW=$(echo "$PROMPT" | claude -p "${CLAUDE_ARGS[@]}" "Classify this user message into one or more categories. For each match, output the corresponding line EXACTLY as shown. Output NOTHING else — no categories, no prefixes, no explanation. If none match, output nothing.

Run /code-quality before writing code.
Run /critical-thinking before proceeding.
Run /critical-evaluation before responding." 2>/dev/null || true)

# Parse JSON and output result + log in one step
echo "$RAW" | python3 -c "
import sys, json, os
from datetime import datetime
try:
    data = json.load(sys.stdin)
    result = data.get('result', '').strip()
    cost = data.get('total_cost_usd', 0)
    api_ms = data.get('duration_api_ms', 0)
    total_ms = data.get('duration_ms', 0)
    tokens_in = data.get('usage', {}).get('input_tokens', 0)
    tokens_out = data.get('usage', {}).get('output_tokens', 0)
except:
    result, cost, api_ms, total_ms, tokens_in, tokens_out = '', 0, 0, 0, 0, 0

# Log
log_file = os.environ.get('LOG_FILE', '')
prompt = os.environ.get('CLASSIFIER_PROMPT', '')[:80]
ts = datetime.now().astimezone().isoformat(timespec='seconds')
label = result.replace(chr(10), ' | ') if result else 'NO_MATCH'
with open(log_file, 'a') as f:
    f.write(f'{ts} | {label} | \${cost:.6f} {api_ms}ms/{total_ms}ms {tokens_in}in+{tokens_out}out | {prompt}\n')

# Output result to stdout (injected as system-reminder)
if result:
    print(result)
" 2>/dev/null

exit 0
