#!/usr/bin/env bash
# Logs UserPromptSubmit hook input to a file for debugging
# Skip logging for classifier's internal claude -p calls
[ "${CLAUDE_AUTO_SKILLS_CLASSIFYING:-}" = "1" ] && exit 0

# Paths: env vars > XDG spec > defaults
STATEDIR="${CLAUDE_AUTO_SKILLS_STATE:-${XDG_STATE_HOME:-$HOME/.local/state}/claude-auto-skills}"
mkdir -p "$STATEDIR"
LOG_FILE="${STATEDIR}/hook-debug.log"
INPUT=$(cat)
eval "$(echo "$INPUT" | python3 -c "
import sys, json, shlex
try:
    data = json.load(sys.stdin)
    print(f'PROMPT={shlex.quote(data.get(\"prompt\", \"\")[:80])}')
    keys = sorted(data.keys())
    print(f'HOOK_KEYS={shlex.quote(\",\".join(keys))}')
    has_cost = 'true' if 'total_cost_usd' in str(data) else 'false'
    print(f'HAS_COST={has_cost}')
except:
    print('PROMPT=\"parse-error\"')
    print('HOOK_KEYS=\"\"')
    print('HAS_COST=false')
" 2>/dev/null)"
echo "$(date -Is) UserPromptSubmit | keys=${HOOK_KEYS} | has_cost=${HAS_COST} | ${PROMPT}" >> "$LOG_FILE"
